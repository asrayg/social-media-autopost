# =============================================================================
# Database
# =============================================================================
# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/social_autopost?schema=public"

# =============================================================================
# Redis
# =============================================================================
# Redis connection string used by BullMQ and ioredis.
# Format: redis://[:password@]HOST:PORT[/db-number]
REDIS_URL="redis://localhost:6379"

# =============================================================================
# NextAuth
# =============================================================================
# A long, random, secret string used to sign/encrypt session tokens.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-very-long-random-string"

# The canonical URL of your deployment — no trailing slash.
# In development this is typically http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# File Storage Directories
# =============================================================================
# Absolute path where user-uploaded raw media files are stored.
UPLOAD_DIR="/Users/you/social-media-autopost/uploads"

# Absolute path where Playwright browser session data (cookies, storage) is
# persisted so accounts stay logged in between runs.
SESSIONS_DIR="/Users/you/social-media-autopost/sessions"

# Absolute path where worker log files are written.
LOGS_DIR="/Users/you/social-media-autopost/logs"

# Absolute path where post-processed (resized / re-encoded) media files are
# stored before being published.
PROCESSED_DIR="/Users/you/social-media-autopost/processed"

# =============================================================================
# TikTok Content Posting API (OFFICIAL — required for native photo carousels)
# =============================================================================
# All OPTIONAL: the app runs without them, but native TikTok photo carousels
# (media_type PHOTO) can only be posted when these are set and your TikTok app
# has been approved for the Content Posting scopes. Video posting still works
# via browser automation regardless. See docs/TIKTOK_API.md for full setup.
#
# Create an app at https://developers.tiktok.com, add the "Content Posting API"
# product, and copy the client key/secret here.
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# OAuth redirect URI — must EXACTLY match one registered in the TikTok console.
# If unset, defaults to `${NEXTAUTH_URL}/api/tiktok/oauth/callback`.
TIKTOK_REDIRECT_URI="http://localhost:3000/api/tiktok/oauth/callback"

# =============================================================================
# Extra platforms (Reddit / YouTube)
# =============================================================================
# Reddit: target community for posts (subreddit name without "r/"). If unset,
# posts go to the account owner's profile (u/<username>).
REDDIT_TARGET_SUBREDDIT=

# YouTube: default visibility for uploads — PUBLIC | UNLISTED | PRIVATE.
# Defaults to PRIVATE if unset.
YOUTUBE_VISIBILITY=UNLISTED

# =============================================================================
# Bluesky (AT Protocol API — no browser session needed)
# =============================================================================
# Your Bluesky handle (e.g. name.bsky.social). Defaults to the account username.
BLUESKY_IDENTIFIER=
# An App Password from Bluesky → Settings → App Passwords (NOT your main password).
BLUESKY_APP_PASSWORD=
# Optional custom PDS service (defaults to https://bsky.social).
BLUESKY_SERVICE=

# Pinterest: board name to pin to (defaults to your first/default board).
PINTEREST_BOARD=
